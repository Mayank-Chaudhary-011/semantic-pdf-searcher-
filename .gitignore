# ============================================================
# .gitignore — Study PDF Search
# ============================================================

# ── Secrets & Environment ────────────────────────────────────
.env
.env.local
.env.*.local

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
venv/
.venv/
envs/
env/

# ── Node / Frontend ──────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.vite/

# ── User Data (never commit) ─────────────────────────────────
# Uploaded PDFs (served at runtime, not part of source)
api/uploads/
uploads/

# Per-user vector indexes (generated at runtime)
turbovec_indexes/

# ── Dev / Test Artifacts ─────────────────────────────────────
fake_scan_test.pdf
test_highlighted.pdf
*.log

# ── OS / Editor ──────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
.vscode/
*.swp
*.swo

# ── Misc ─────────────────────────────────────────────────────
*.tmp
*.bak